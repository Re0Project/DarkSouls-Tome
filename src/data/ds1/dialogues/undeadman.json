    },
    {
      "index": 73,
      "chn": "谢谢惠顾。",
      "jap": "ありがとうごぜえました",
      "eng": "Ah, thank you, very much.",
      "isUnused": false,
      "isTitle": false
    },
    {
      "index": 74,
      "chn": "欢迎再度光临……",
      "jap": "今後ともご贔屓に…",
      "eng": "Come back soon!",
      "isUnused": false,
      "isTitle": false
    },
    {
      "index": 75,
      "chn": "嘻嘻嘻",
      "jap": "イヒヒヒヒヒッ",
      "eng": "Nee hee hee hee hee!",
      "isUnused": false,
      "isTitle": false
    },
    {
      "index": 76,
      "chn": "#0走开中断对话",
      "jap": "#0彼から離れて",
      "eng": "#0After leaving abruptly",
      "isUnused": false,
      "isTitle": true
    },
    {
      "index": 77,
      "chn": "欸，怎么了，你要去哪？",
      "jap": "あん、なんだ？どうした？",
      "eng": "Hey, what! What's the matter?",
      "isUnused": false,
      "isTitle": false
    },
    {
      "index": 78,
      "chn": "#0走开中断对话后，返回攀谈",
      "jap": "#0話しかけた:離れてから戻った",
