      "eng": "#0Menu-Choose \"Leave\" 1st time without purchasing something",
      "isUnused": false,
      "isTitle": true
    },
    {
      "index": 57,
      "chn": "啧",
      "jap": "ちぇ",
      "eng": "Hmph!",
      "isUnused": false,
      "isTitle": false
    },
    {
      "index": 58,
      "chn": "真小气。",
      "jap": "けちくさいねぇ",
      "eng": "Cheap bastard.",
      "isUnused": false,
