    },
    {
      "index": 1,
      "chn": "唷，你好啊。",
      "jap": "やあ、こんにちは",
      "eng": "Aye, siwmae.",
      "isUnused": false,
      "isTitle": false
    },
    {
      "index": 2,
      "chn": "很高兴见到你。",
      "jap": "はじめまして",
      "eng": "And good day to you.",
      "isUnused": false,
      "isTitle": false
    },
    {
      "index": 3,
      "chn": "我是杰纳的德纳尔，",
      "jap": "私はゼナのドーナル",
      "eng": "I'm Domhnall of Zena.",
      "isUnused": false,
      "isTitle": false
    },
    {
      "index": 4,
      "chn": "算是……做买卖的吧。",
      "jap": "なんというか…商い者さ",
      "eng": "I'm just, well, a peddler, of sorts.",
      "isUnused": false,
      "isTitle": false
    },
    {
      "index": 5,
      "chn": "我最喜欢珍奇异品，有的话可以卖给我喔。",
      "jap": "珍品奇品、取引するよ。大好きなんだ",
      "eng": "I adore trinkets and oddities, so I trade for them.",
      "isUnused": false,
      "isTitle": false
    },
