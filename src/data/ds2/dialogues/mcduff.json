      "eng": "What?!",
      "isUnused": false,
      "isTitle": false
    },
    {
      "index": 19,
      "chn": "哈！你是不通情理的狂人吗!!",
      "jap": "はっ！道理もわからぬ狂人か！！",
      "eng": "Hmph! Oh, do it yourself, then!",
      "isUnused": false,
      "isTitle": false
    },
